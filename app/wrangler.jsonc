{
  // Cloudflare Workers（静的アセット配信）のデプロイ設定
  // SPAフォールバックはnot_found_handlingで行う（_redirectsの `/* /index.html 200` は
  // .html正規化との無限ループとして拒否されるため使わない）
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cumulog",
  "compatibility_date": "2026-07-11",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
